# --- Golden-fixture generation scratch ---
# .goldtmp is the staging dir created by the snode/optimize golden harnesses;
# committed fixtures (snode_golden.json, optimize_golden.json, harness.*,
# regenerate.sh) are kept — only transient intermediates are ignored.
/.goldtmp/
**/testdata/_blocks.json
**/testdata/*.tmp
**/testdata/err.txt

